{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"],
      "@/lib/*": ["../../lib/*"],
      "@/lib": ["../../lib"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"],
  "references": [{ "path": "../../" }]
}
