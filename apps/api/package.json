{
  "name": "@launchkit-ai/api",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "vitest run --config=vitest.config.ts",
    "test:watch": "vitest --config=vitest.config.ts",
    "test:setup": "echo 'Test setup handled by vitest config'",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@launchkit-ai/sdk": "workspace:*",
    "@prisma/client": "*",
    "fastify": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "vitest-mock-extended": "^3.1.0"
  }
}
