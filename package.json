{
  "name": "launchkit-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "node scripts/dev-environment.mjs",
    "dev:api": "node scripts/dev-environment.mjs --services=api",
    "dev:web": "node scripts/dev-environment.mjs --services=web",
    "dev:ui": "node scripts/dev-environment.mjs --services=ui",
    "dev:minimal": "node scripts/dev-environment.mjs --services=api,web --no-dashboard",
    "build": "turbo run build",
    "test": "node scripts/test-router.mjs",
    "test:root": "vitest run",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo run type-check",
    "prisma": "prisma",
    "prisma:migrate": "turbo run prisma:migrate",
    "prisma:generate": "turbo run prisma:generate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky install",
    "test:api": "turbo run test --filter=@launchkit-ai/api",
    "test:sdk": "turbo run test --filter=@launchkit-ai/sdk",
    "test:web": "turbo run test --filter=@launchkit-ai/web",
    "test:ui": "turbo run test --filter=@launchkit-ai/ui",
    "test:common": "turbo run test --filter=@launchkit-ai/common",
    "test:unit": "node scripts/test-router.mjs --pattern=common,sdk,api,ui",
    "test:integration": "pnpm test:api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:storybook": "cd packages/ui && pnpm test-storybook",
    "test:visual": "cd packages/ui && pnpm chromatic",
    "storybook": "cd packages/ui && pnpm storybook",
    "storybook:build": "cd packages/ui && pnpm build-storybook",
    "test:watch": "node scripts/test-router.mjs --watch",
    "test:coverage": "node scripts/test-router.mjs --coverage",
    "test:clean": "find . -name 'test-*.db' -delete && find . -name '*.tsbuildinfo' -delete",
    "test:security": "cd apps/api && pnpm test:security",
    "security:scan": "semgrep scan --config=.semgrep.yml --error",
    "security:deps": "pnpm audit --audit-level=high",
    "generate:exports": "node scripts/generate-component-exports.mjs",
    "build:optimized": "turbo run build --concurrency=4 --cache-dir=.turbo/cache"
  },
  "dependencies": {
    "@fastify/caching": "^9.0.3",
    "@fastify/compress": "^8.0.0",
    "@hookform/resolvers": "3.2.0",
    "@mozilla/readability": "0.6.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.62.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.203.0",
    "@opentelemetry/instrumentation-fastify": "^0.48.0",
    "@opentelemetry/sdk-node": "^0.203.0",
    "@prisma/client": "6.15.0",
    "@sentry/node": "^10.8.0",
    "jsdom": "23.0.0",
    "next": "15.5.2",
    "prisma": "^6.15.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "7.46.0",
    "stripe": "14.1.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@eslint/js": "^9.34.0",
    "@playwright/test": "^1.55.0",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.14.9",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "10.4.19",
    "axe-playwright": "^2.1.0",
    "eslint": "^9.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^8.0.0",
    "jest-image-snapshot": "^6.5.1",
    "lint-staged": "^15.0.0",
    "postcss": "8.4.39",
    "prettier": "^3.0.0",
    "semgrep": "^0.0.1",
    "supertest": "^7.1.4",
    "tailwindcss": "3.4.9",
    "testcontainers": "^11.5.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "lucide-react": "^0.542.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
