{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
  "composite": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/lib/*": ["./lib/*"],
      "@/styles/*": ["./styles/*"],
      "@/app/*": ["./app/*"],
  "@launchkit/common": ["./packages/common/src/index.ts"],
  "@launchkit/common/*": ["./packages/common/src/*"],
  "@launchkit/ui": ["./packages/ui/src/index.ts"],
  "@launchkit/ui/*": ["./packages/ui/src/*"],
  "@launchkit/sdk": ["./packages/sdk/src/index.ts"],
  "@launchkit/sdk/*": ["./packages/sdk/src/*"],
  "@launchkit-ai/ui": ["./packages/ui/src/index.ts"],
  "@launchkit-ai/ui/*": ["./packages/ui/src/*"],
  "@launchkit-ai/sdk": ["./packages/sdk/src/index.ts"],
  "@launchkit-ai/sdk/*": ["./packages/sdk/src/*"],
  "@launchkit-ai/common": ["./packages/common/src/index.ts"],
  "@launchkit-ai/common/*": ["./packages/common/src/*"],
      "@launchkit-ai/lib": ["./packages/lib/src/index.ts"],
      "@launchkit-ai/lib/*": ["./packages/lib/src/*"],
      "@launchkit/tests": ["./packages/tests/src/index.ts"],
      "@launchkit/tests/*": ["./packages/tests/src/*"]
    },
    "jsx": "preserve",
    "allowJs": true,
  "types": ["vitest/globals"],
    "skipLibCheck": true,
    "incremental": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "eslint.config.base.js",
    "apps/**/*",
    "packages/**/*",
    "lib/**/*"
  ],
  "exclude": ["node_modules", ".next", "**/node_modules", "**/dist", "**/build", "**/test/**"]
}
