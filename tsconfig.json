{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/lib/*": ["./lib/*"],
      "@/styles/*": ["./styles/*"],
      "@/app/*": ["./app/*"],
      "@launchkit/common": ["./packages/common/src/index.ts"],
      "@launchkit/common/*": ["./packages/common/src/*"],
      "@launchkit/ui": ["./packages/ui/src/index.ts"],
      "@launchkit/ui/*": ["./packages/ui/src/*"],
      "@launchkit/sdk": ["./packages/sdk/src/index.ts"],
      "@launchkit/sdk/*": ["./packages/sdk/src/*"],
      "@launchkit-ai/lib": ["./packages/lib/src/index.ts"],
      "@launchkit-ai/lib/*": ["./packages/lib/src/*"],
      "@launchkit/tests": ["./packages/tests/src/index.ts"],
      "@launchkit/tests/*": ["./packages/tests/src/*"]
    },
    "jsx": "preserve",
    "allowJs": true,
    "skipLibCheck": true,
    "incremental": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "apps/**/*",
    "packages/**/*",
    "lib/**/*"
  ],
  "exclude": ["node_modules", ".next", "**/node_modules", "**/dist", "**/build"]
}
