{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "prisma:generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**", "prisma/migrations/**"]
    },
    "prisma:migrate": {
      "cache": false,
      "outputs": ["prisma/migrations/**"]
    }
  }
}
