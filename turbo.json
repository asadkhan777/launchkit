{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "test": {
      "dependsOn": ["build", "prisma:generate"],
      "outputs": ["coverage/**"],
      "cache": false,
      "env": ["NODE_ENV", "DATABASE_URL"]
    },
    "test:watch": {
      "dependsOn": ["build", "prisma:generate"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": []
    },
    "prisma:generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**"]
    },
    "prisma:migrate": {
      "cache": false,
      "outputs": ["prisma/migrations/**"]
    },
    "prisma:push": {
      "cache": false,
      "outputs": []
    }
  }
}
